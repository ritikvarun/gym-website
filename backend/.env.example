PORT=10000

# MongoDB — Direct hosts format (Windows fix)
MONGO_URI=mongodb://USERNAME:PASSWORD@host-00.xxxxx.mongodb.net:27017,host-01.xxxxx.mongodb.net:27017,host-02.xxxxx.mongodb.net:27017/gym_db?ssl=true&authSource=admin

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT
JWT_SECRET=strong_random_secret_here

# Email & Notification Settings
# For Gmail SMTP:
EMAIL_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_username@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_RECEIVER=receiver_email@gmail.com

# For Resend (Alternative):
RESEND_API_KEY=re_xxxxxxxxxxxx
GYM_EMAIL=your_gym_email@gmail.com

# WhatsApp Number for Direct Leads (Include country code without +, e.g., 919876543210)
WHATSAPP_NUMBER=919876543210

